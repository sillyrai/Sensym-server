<form id="new-analytics-form">
    <p class="form_title">Time period</p>
    <div>
        <p class="input_label">from: </p>
        <input id="new_analytics-form-input" type="date" name="period_from"/>
    </div>
    <div>
        <p class="input_label">to: </p>
        <input id="new_analytics-form-input" type="date" name="period_to"/>
    </div>

    <div>
        <p class="input_label">Sensor</p>
        <select name="cars" id="cars">
            <%  sensors.forEach(s => { %>
                <option value="<%= s._id %>"><%= s.name %></option>
            <% });%>
        </select>
    </div>

    <div>
        <p class="input_label">Analytics type</p>
        <select name="cars" id="cars">
            <option value="avg">Average</option>
        </select>
    </div>

    <input type="submit" value="Create" />
</form>

<script>

    const newAnalyticsForm = document.getElementById("new-analytics-form");

    newAnalyticsForm.addEventListener("submit", function(e) {
        e.preventDefault();

        const data = new FormData(newAnalyticsForm);
        
        for (const [name,value] of data) {
            console.log(name, ":", value);
        }
    })

