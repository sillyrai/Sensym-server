<form id="new-analytics-form">
    <p class="form_title">Time period</p>
    <div>
        <p class="input_label">from: </p>
        <input id="period_from" type="datetime-local" name="period_from"/>
    </div>
    <div>
        <p class="input_label">to: </p>
        <input id="period_to" type="datetime-local" name="period_to"/>
    </div>

    <div>
    <div>
        <p class="input_label">Sensor</p>
        <select name="sensor" id="input_sensor">
            <%  sensors.forEach(s => { %>
                <option value="<%= s.token %>"><%= s.name %></option>
            <% });%>
        </select>
    </div>
    </div>

    <div>
        <p class="input_label">Analytics type</p>
        <select name="analytics_type" id="input_analytics_type">
            <option value="avg">Average</option>
        </select>
    </div>

    <input type="submit" value="Create" />
</form>

<script>
document.addEventListener("DOMContentLoaded", () => {
    const newAnalyticsForm = document.getElementById("new-analytics-form");
    const fromInput = document.getElementById("period_from");
    const toInput = document.getElementById("period_to");

    function formatDateTime(date) {
        return new Date(date.getTime() - (date.getTimezoneOffset() * 60000))
            .toISOString()
            .slice(0, 16);
    }

    const now = new Date();
    const hourAgo = new Date(now.getTime() - (60 * 60 * 1000));

    fromInput.value = formatDateTime(hourAgo);
    toInput.value = formatDateTime(now);

    newAnalyticsForm.addEventListener("submit", async function(e) {
        e.preventDefault();

        const sensorSelect = document.getElementById('input_sensor');
        const sensorId = sensorSelect.value;
        const sensorName = sensorSelect.options[sensorSelect.selectedIndex].text;
        
        const fromVal = fromInput.value;
        const toVal = toInput.value;
        
        const endpoint = `/api/sensors/${sensorId}?from=${encodeURIComponent(fromVal)}&to=${encodeURIComponent(toVal)}`;

        try {
            const response = await fetch(endpoint);
            
            if (!response.ok) {
                throw new Error(`Server returned a ${response.status} error`);
            }

            const result = await response.json();
            let records = result.data;
            
            if (!records) {
                throw new Error("No data array found in the response");
            }

            const fromTime = new Date(fromVal).getTime();
            const toTime = new Date(toVal).getTime();
            
            records = records.filter(r => {
                const recordTime = new Date(r.createdAt).getTime();
                return recordTime >= fromTime && recordTime <= toTime;
            });

            if (records.length === 0) {
                alert("No data found for this time range!");
                return;
            }

            const listContainer = document.querySelector('.analytics-list');

            let sensorContainer = document.getElementById(`sensor-wrapper-${sensorId}`);
            
            if (!sensorContainer) {
                sensorContainer = document.createElement('div');
                sensorContainer.id = `sensor-wrapper-${sensorId}`;
                
                sensorContainer.style.boxSizing = 'border-box'; 
                sensorContainer.style.width = '95%'; 
                sensorContainer.style.margin = '25px auto 25px auto'; 
                
                sensorContainer.style.border = '1px solid #333'; 
                sensorContainer.style.backgroundColor = '#1e1e1e'; 
                sensorContainer.style.borderRadius = '12px';
                sensorContainer.style.padding = '40px 20px'; 
                
                listContainer.prepend(sensorContainer); 
            }

            sensorContainer.innerHTML = '';

            const sensorTitle = document.createElement('h2');
            sensorTitle.innerText = `Data for: ${sensorName}`;
            sensorTitle.style.color = '#e0e0e0';
            sensorTitle.style.textAlign = 'center';
            sensorTitle.style.margin = '0 0 30px 0';
            sensorContainer.appendChild(sensorTitle);

            const datasetsMap = {};
            records.forEach(record => {
                record.data.forEach(metric => {
                    if (!datasetsMap[metric.name]) {
                        datasetsMap[metric.name] = { data: [] };
                    }
                    datasetsMap[metric.name].data.push(parseFloat(metric.value));
                });
            });

            const averagesList = [];
            for (const [metricName, metricData] of Object.entries(datasetsMap)) {
                if (metricData.data.length > 0) {
                    const sum = metricData.data.reduce((a, b) => a + b, 0);
                    const avg = (sum / metricData.data.length).toFixed(2);
                    averagesList.push(`${metricName}: ${avg}`);
                }
            }       

            const analyticsSelect = document.getElementById('input_analytics_type');
            const selectedTypeName = analyticsSelect.options[analyticsSelect.selectedIndex].text;
            
            const statsContainer = document.createElement('div');
            statsContainer.style.display = 'flex';
            statsContainer.style.alignItems = 'center';
            statsContainer.style.justifyContent = 'center'; 
            statsContainer.style.gap = '25px'; 
            statsContainer.style.flexWrap = 'wrap'; 

            const titleText = document.createElement('h3');
            titleText.innerText = `${selectedTypeName}:`;
            titleText.style.margin = '0';
            titleText.style.color = '#888'; 
            titleText.style.width = '100%';
            titleText.style.textAlign = 'center';
            titleText.style.fontSize = '2rem';
            titleText.style.marginBottom = '25px';
            statsContainer.appendChild(titleText);

            averagesList.forEach(stat => {
                const statBadge = document.createElement('div');
                statBadge.className = 'analytics-badge';
                
                statBadge.style.border = '2px solid rgb(46, 161, 80)'; 
                statBadge.style.backgroundColor = 'rgba(46, 161, 80, 0.1)'; 
                statBadge.style.borderRadius = '12px';
                statBadge.style.padding = '20px 35px';
                statBadge.style.fontSize = '1.5rem'; 
                statBadge.style.fontWeight = '900';
                statBadge.style.color = 'rgb(76, 191, 110)'; 
                statBadge.style.boxShadow = '0 8px 15px rgba(0,0,0,0.3)'; 
                
                statBadge.innerText = stat;
                statsContainer.appendChild(statBadge);
            });

            sensorContainer.appendChild(statsContainer);

        } catch (error) {
            console.error("STUFF:", error);
            alert("Something broke lol check the console");
        }
    });
});
</script>