<script src="/socket.io/socket.io.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns"></script>
<script>
const socket = io();

const currentSensorId = "<%= sensor.id %>";
const sensorDataSet = <%- JSON.stringify(data) %>;
const exportSensorDataSet = <%- JSON.stringify(allData) %>;

let theChart = null;

const chartMinuteLenght = 30;
const tick_color = "#777";
const grid_color = "#444";

const dataDateFormat = <%- JSON.stringify(dataDateFormat) %>;
const dataTimeFormat = <%- JSON.stringify(dataTimeFormat) %>;
const sensorDataTypeToMesurement = {
    "temperature": "º C",
    "humidity": "% RH"
}

const dataTableElement = document.getElementById("data_table");
const exportJsonButton = document.getElementById("export_json_button");
const exportCsvButton = document.getElementById("export_csv_button");

function sortedSensorData(dataSet) {
    return [...dataSet].sort((a, b) => new Date(a.createdAt) - new Date(b.createdAt));
}

function downloadTextFile(fileContent, fileName, mimeType) {
    const blob = new Blob([fileContent], { type: `${mimeType};charset=utf-8` });
    const downloadLink = document.createElement("a");
    const objectUrl = URL.createObjectURL(blob);

    downloadLink.href = objectUrl;
    downloadLink.download = fileName;
    downloadLink.style.display = "none";

    document.body.appendChild(downloadLink);
    downloadLink.click();
    downloadLink.remove();

    URL.revokeObjectURL(objectUrl);
}

function csvEscape(value) {
    const stringValue = String(value ?? "");
    if (/[",\n\r]/.test(stringValue)) {
        return `"${stringValue.replace(/"/g, '""')}"`;
    }
    return stringValue;
}

function buildCsvRows(dataSet) {
    const sortedData = sortedSensorData(dataSet);
    const columns = sortedData[0]?.data.map((item, index) => ({
        key: index,
        label: item.name ? `${item.name} (${item.type})` : item.type
    })) || [];

    const headerRow = ["createdAt", "date", "time", ...columns.map(column => column.label)];
    const rows = sortedData.map(entry => {
        const createdAt = new Date(entry.createdAt);
        const values = columns.map(column => csvEscape(entry.data[column.key]?.value ?? ""));

        return [
            csvEscape(createdAt.toISOString()),
            csvEscape(createdAt.toLocaleDateString("sv-SE")),
            csvEscape(createdAt.toLocaleTimeString("sv-SE", { hour12: false })),
            ...values
        ].join(",");
    });

    return [headerRow.map(csvEscape).join(","), ...rows].join("\n");
}

function exportJsonData() {
    downloadTextFile(
        JSON.stringify(sortedSensorData(exportSensorDataSet), null, 2),
        `sensor-${currentSensorId}.json`,
        "application/json"
    );
}

function exportCsvData() {
    downloadTextFile(
        buildCsvRows(exportSensorDataSet),
        `sensor-${currentSensorId}.csv`,
        "text/csv"
    );
}

if (exportJsonButton) {
    exportJsonButton.addEventListener("click", exportJsonData);
}

if (exportCsvButton) {
    exportCsvButton.addEventListener("click", exportCsvData);
}

function updateDataGraph() {
    // Sort data
    sensorDataSet.sort((a, b) =>
        new Date(a.createdAt) - new Date(b.createdAt)
    );

    // Create a an X an Y map from all the data
    const chartData = sensorDataSet.map(item => ({
        x: new Date(item.createdAt),
        y: Number(item.data[0].value)
    })).filter(point => !isNaN(point.y));

    // Filter to last 30 minutes
    const now = new Date();
    const thirtyMinutesAgo = new Date(now.getTime() - chartMinuteLenght * 60 * 1000);
    const recentChartData = chartData.filter(point => point.x >= thirtyMinutesAgo && point.x <= now);

    if (theChart) {
        theChart.data.datasets[0].data = recentChartData;
        theChart.options.scales.x.min = thirtyMinutesAgo;
        theChart.options.scales.x.max = now;
        
        // Render the updates smoothly
        theChart.update();
        return; 
    }

    const ctx = document.getElementById('sensor_data_line_graph').getContext('2d');
    theChart = new Chart(ctx, {
        type: 'line',
        data: {
            datasets: [{
                label: 'Temperature (°C)',
                data: recentChartData,
                borderColor: 'rgb(46, 161, 80)',
                backgroundColor: 'rgba(255, 255, 255, 0)',
                tension: 0.3,
                fill: false,
                borderWidth: 2,
                pointRadius: 0,
                pointHoverRadius: 0
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            parsing: false,
            scales: {
                x: {
                    type: 'time',
                    time: {
                        unit: 'minute',
                        stepSize: chartMinuteLenght,
                        displayFormats: {
                            minute: 'HH:mm'
                        },
                        tooltipFormat: 'HH:mm'
                    },
                    min: thirtyMinutesAgo,
                    max: now,
                    grid: {
                        color: grid_color,
                        borderColor: grid_color,
                        drawTicks: true
                    },
                    ticks: {
                        color: tick_color,
                        font: { size: 12 }
                    }
                },
                y: {
                    title: {
                        display: true,
                        text: `${sensorDataSet[0].data[0].type} (${sensorDataTypeToMesurement[sensorDataSet[0].data[0].type]})`
                    },
                    beginAtZero: false,
                    grid: {
                        color: grid_color,
                        borderColor: grid_color,
                        drawTicks: true
                    },
                    ticks: {
                        color: tick_color,
                        font: { size: 12 },
                        precision: 0
                    }
                }
            },
            plugins: {
                legend: {
                    display: false
                }
            },
        }
    });
}

function updateDataTable(data) {
    const createdAtUNIX = new Date(data.createdAt);

    dataTableElement.insertAdjacentHTML("afterbegin", `
    <tr class="index_col">   
        <td class="time_col">
            ${createdAtUNIX.toLocaleTimeString("lv-LV", dataTimeFormat)}
        </td>

        <td class="date_col">
            ${createdAtUNIX.toLocaleDateString("lv-LV", dataDateFormat)}
        </td>
        
        ${data.data.map(a => `<td class="data_col">${a.value}${sensorDataTypeToMesurement[a.type]}</td>`).join('')}
    </tr>
    `)
}

function onNewIncomingData(newData) {
    sensorDataSet.push(newData);
    exportSensorDataSet.push(newData);
    updateDataGraph();
    updateDataTable(newData);
}


document.addEventListener('DOMContentLoaded', function () {
    updateDataGraph();
});


socket.on('connect', () => {
    // console.log('Connected to WebSocket server');
    socket.emit('live_sensor_data_flow', currentSensorId);
});

socket.on('new_sensor_data', (data) => {
    onNewIncomingData(data);
});

// socket.on('disconnect', () => { console.log('Disconnected from server'); });
</script>