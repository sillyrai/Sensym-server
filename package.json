{
	"type": "commonjs",
	"scripts": {
		"start": "npm run dep:sass && npm run dep:server",
		"dep:sass": "sass src/Sass:src/Public/css",
		"dep:server": "ts-node src/server.ts",
		"dev": "concurrently \"npm run dev:server\" \"npm run dev:sass\"",
		"dev:server": "nodemon --exec ts-node src/server.ts",
		"dev:sass": "sass --watch src/Sass:src/Public/css"
	},
	"dependencies": {
		"@types/bcrypt": "^6.0.0",
		"@types/cookie-parser": "^1.4.10",
		"@types/express": "^5.0.6",
		"@types/jsonwebtoken": "^9.0.10",
		"bcrypt": "^6.0.0",
		"concurrently": "^9.2.1",
		"connect-flash": "^0.1.1",
		"cookie-parser": "^1.4.7",
		"dotenv": "^17.2.3",
		"ejs": "^4.0.1",
		"express": "^5.2.1",
		"express-session": "^1.19.0",
		"jsonwebtoken": "^9.0.3",
		"mongoose": "^9.0.0",
		"nodemon": "^3.1.11",
		"sass": "^1.94.2",
		"socket.io": "^4.8.3",
		"ts-node": "^10.9.2"
	},
	"overrides": {
		"minimatch": "^10.2.2"
	}
}
