<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Analytics</title>

    <link rel="stylesheet" href="/css/global.css">
    <% if (typeof styles !=='undefined' && styles.length) { %>
        <% styles.forEach(href=> { %>
            <link rel="stylesheet" href="/css/<%= href %>">
            <% }); %>
                <% } %>
</head>

<body>
    <%- include('Components/navabar') %>

        <main>
            <% stats.forEach(sensor => {
                const end = Date.now();
                const start = end - (30 * 60 * 1000); // last 30 minutes
                const width = 1800;
                const height = 200;

                // Horizontal grid lines
                const hLines = [50, 100, 150];


                
                // Vertical lines every 5 minutes
                const fiveMin = 5 * 60 * 1000;
                const vLines = [];
                for(let t = start; t <= end; t += fiveMin) {
                    vLines.push(((t - start) / (end - start)) * width);
                }

                // Compute Y scaling
                const values = sensor.data.map(d => d.value);
                const min = Math.min(...values);
                const max = Math.max(...values);
                const range = max - min || 1;
                

                // Build data points and path
                let pathD = "";
                const points = sensor.data.map((d, i) => {
                    const timestamp = new Date(d.time).getTime();
                    const x = ((timestamp - start) / (end - start)) * width;
                    const y = height - ((d.value - min) / range) * height;

                    if(i === 0) pathD += `M${x} ${y}`;
                    else pathD += ` L${x} ${y}`;

                    return { x, y };
                });
            %>

            <div class="section">
                <h3><%= sensor.sensorName %></h3>
                <p><%= sensor.dataType %></p>
                <svg class="chart" id="chart-<%= sensor.sensorID %>"
                    height="200"
                    width="100%"
                    viewBox="0 0 1800 200"
                    preserveAspectRatio="none"
                    xmlns="http://www.w3.org/2000/svg">

                    <!-- Horizontal grid lines -->
                    <% hLines.forEach(y => { %>
                        <line x1="0" y1="<%= y %>" x2="<%= width %>" y2="<%= y %>" stroke="#ccc" stroke-width="1"/>
                    <% }); %>

                    <!-- Vertical grid lines every 5 min -->
                    <% vLines.forEach(x => { %>
                        <line x1="<%= x %>" y1="0" x2="<%= x %>" y2="<%= height %>" stroke="#eee" stroke-width="2" />
                    <% }); %>

                    <!-- Data points -->
                    <% points.forEach(p => { %>
                        <circle cx="<%= p.x %>" cy="<%= p.y %>" r="3" fill="red" />
                    <% }); %>

                    <!-- Line connecting points -->
                    <path d="<%= pathD %>" stroke="red" fill="none" stroke-width="2" />
                </svg>
            </div>
            <% }); %>
        </main>
</body>
<%- include('Scripts/chart', {stats}) %>

</html>