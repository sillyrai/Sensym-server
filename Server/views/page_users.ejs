<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Analytics</title>

    <link rel="stylesheet" href="/css/global.css">
    <% if (typeof styles !=='undefined' && styles.length) { %>
        <% styles.forEach(href=> { %>
            <link rel="stylesheet" href="/css/<%= href %>">
        <% }); %>
    <% } %>
</head>

<body>
    <%- include('Components/navabar') %>
    <a class="add_users_btn" href="/users/add"><img src="/graphics/plus.svg"></a>

    <main>
        <div class="user_list_holder"><div class="user_list">
        <% if (typeof users !== 'undefined') { %>
            <% users.forEach(user => { %>
            <a class="user" href="/sensors/<%= sensor.id %>">
                <img class="user_pfp" src="/assets/logo.png" alt="...">
                <p class="user_name"><%= user.name %></p>
            </a>
            <% }) %>
        <% } %>
        </div></div>
    </main>
</body>
<%- include('Scripts/chart') %>
</html>